# Template for the Kubernetes Secret holding the Fernet encryption key.
# DO NOT COMMIT the encryption-key.yaml file (without .example) — it is in .gitignore.
#
# Generate a Fernet key:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Base64-encode it for this manifest:
#   echo -n "<fernet_key>" | base64
#
# OpenFaaS mounts the key as a file:
#   /var/openfaas/secrets/FERNET_KEY
# Handler mapping: _read_secret("FERNET_KEY")
apiVersion: v1
kind: Secret
metadata:
  name: encryption-key
  namespace: openfaas-fn
type: Opaque
data:
  # echo -n "<generated_fernet_key>" | base64
  FERNET_KEY: <BASE64_FERNET_KEY>
