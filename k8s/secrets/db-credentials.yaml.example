# Template for the Kubernetes Secret holding the PostgreSQL credentials.
# DO NOT COMMIT the db-credentials.yaml file (without .example) — it is in .gitignore.
#
# Values must be base64-encoded:
#   echo -n "value" | base64
#
# OpenFaaS mounts each key of this Secret as a file under:
#   /var/openfaas/secrets/<key>
# Example: the DB_HOST key -> /var/openfaas/secrets/DB_HOST
#
# Mapping to the handler:
#   _read_secret("DB_HOST")      -> DB_HOST key
#   _read_secret("DB_NAME")      -> DB_NAME key
#   _read_secret("DB_USER")      -> DB_USER key
#   _read_secret("DB_PASSWORD")  -> DB_PASSWORD key
apiVersion: v1
kind: Secret
metadata:
  name: db-credentials
  namespace: openfaas-fn
type: Opaque
data:
  # echo -n "postgresql.openfaas-fn.svc.cluster.local" | base64
  DB_HOST: <BASE64_DB_HOST>
  # echo -n "cofrapdb" | base64
  DB_NAME: <BASE64_DB_NAME>
  # echo -n "cofrapuser" | base64
  DB_USER: <BASE64_DB_USER>
  # echo -n "<password>" | base64
  DB_PASSWORD: <BASE64_DB_PASSWORD>
