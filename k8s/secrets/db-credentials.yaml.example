# Template du Secret Kubernetes pour les credentials PostgreSQL.
# NE PAS COMMITTER le fichier db-credentials.yaml (sans .example) — il est dans .gitignore.
#
# Les valeurs doivent être encodées en base64 :
#   echo -n "valeur" | base64
#
# OpenFaaS monte chaque clé de ce Secret comme un fichier dans :
#   /var/openfaas/secrets/<clé>
# Exemple : la clé DB_HOST → /var/openfaas/secrets/DB_HOST
#
# Correspondance avec le handler :
#   _read_secret("DB_HOST")      → clé DB_HOST
#   _read_secret("DB_NAME")      → clé DB_NAME
#   _read_secret("DB_USER")      → clé DB_USER
#   _read_secret("DB_PASSWORD")  → clé DB_PASSWORD
apiVersion: v1
kind: Secret
metadata:
  name: db-credentials
  namespace: openfaas-fn
type: Opaque
data:
  # echo -n "postgresql.openfaas-fn.svc.cluster.local" | base64
  DB_HOST: <BASE64_DB_HOST>
  # echo -n "cofrapdb" | base64
  DB_NAME: <BASE64_DB_NAME>
  # echo -n "cofrapuser" | base64
  DB_USER: <BASE64_DB_USER>
  # echo -n "<mot_de_passe>" | base64
  DB_PASSWORD: <BASE64_DB_PASSWORD>
